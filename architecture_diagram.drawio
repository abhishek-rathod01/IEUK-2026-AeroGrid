<mxfile host="app.diagrams.net">
  <diagram name="AeroGrid Architecture" id="aerogrid-arch-1">
    <mxGraphModel dx="900" dy="650" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="AeroGrid - Real-Time Turbine Monitoring Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1;fontColor=#0f3d3a;" vertex="1" parent="1">
          <mxGeometry x="120" y="30" width="900" height="30" as="geometry" />
        </mxCell>

        <mxCell id="b1" value="Wind Turbine Fleet&#10;IoT Sensors&#10;(timestamp, temperature, RPM, vibration)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0e7490;fontColor=#0f3d3a;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="190" height="100" as="geometry" />
        </mxCell>

        <mxCell id="b2" value="Ingestion Layer&#10;Apache Kafka / AWS Kinesis&#10;Buffers the massive, non-stop stream" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4338ca;fontColor=#0f3d3a;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="290" y="300" width="210" height="100" as="geometry" />
        </mxCell>

        <mxCell id="b3" value="Stream Processing&#10;AWS Lambda&#10;Real-time anomaly detection&#10;(avg temp &gt; 85&#176;C OR vibration &gt; 15 mm/s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontColor=#0f3d3a;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="560" y="295" width="220" height="110" as="geometry" />
        </mxCell>

        <mxCell id="b4" value="Real-Time Alerting &amp; Dashboard&#10;Amazon SNS + Dashboard&#10;Engineers alerted instantly" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#15803d;fontColor=#0f3d3a;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="840" y="140" width="220" height="100" as="geometry" />
        </mxCell>

        <mxCell id="b5" value="Hot Storage&#10;Time-Series DB (Amazon Timestream)&#10;Live dashboards &amp; fast queries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#be123c;fontColor=#0f3d3a;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="840" y="300" width="220" height="100" as="geometry" />
        </mxCell>

        <mxCell id="b6" value="Cold Storage&#10;Data Lake (Amazon S3)&#10;Low-cost long-term archive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#1d4ed8;fontColor=#0f3d3a;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="840" y="460" width="220" height="100" as="geometry" />
        </mxCell>

        <mxCell id="note" value="Why this design solves AeroGrid's two problems:&#10;1. Legacy server overload -&gt; Kafka / Kinesis absorbs the high-volume stream and decouples ingestion from processing, so no readings are lost.&#10;2. Warning signs buried in logs -&gt; Lambda flags anomalies in real time and alerts engineers instantly, rather than discovering failures after they happen." style="text;html=1;whiteSpace=wrap;align=left;verticalAlign=middle;fillColor=#f1f5f9;strokeColor=#cbd5e1;dashed=1;fontColor=#334155;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="610" width="1020" height="90" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="endArrow=classic;html=1;strokeColor=#64748b;" edge="1" parent="1" source="b1" target="b2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;strokeColor=#64748b;" edge="1" parent="1" source="b2" target="b3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="alerts" style="endArrow=classic;html=1;strokeColor=#64748b;fontSize=10;fontColor=#64748b;" edge="1" parent="1" source="b3" target="b4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;strokeColor=#64748b;" edge="1" parent="1" source="b3" target="b5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="archive" style="endArrow=classic;html=1;strokeColor=#64748b;fontSize=10;fontColor=#64748b;" edge="1" parent="1" source="b3" target="b6"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
